    echo -e "${RED}[ERROR]${NC} $1" >&2
}

# =============================================================================
# JSON Escaping
# =============================================================================
json_escape() {
    local str="$1"
    str="${str//\\/\\\\}"
    str="${str//\"/\\\"}"
    str="${str//$'\n'/\\n}"
    str="${str//$'\t'/\\t}"
    str="${str//$'\r'/}"
    printf '%s' "$str"
}

