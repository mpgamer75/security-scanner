# =============================================================================
# Input Validation
# =============================================================================
validate_ip() {
    local ip="$1"
    # IPv4 validation
    if [[ "$ip" =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]]; then
        local IFS='.'
        read -ra octets <<< "$ip"
        for octet in "${octets[@]}"; do
            if (( octet > 255 )); then
                return 1
            fi
        done
        return 0
    fi
    # CIDR notation (e.g., 192.168.1.0/24)
    if [[ "$ip" =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}/[0-9]{1,2}$ ]]; then
        return 0
    fi
    return 1
}

validate_domain() {
    local domain="$1"
    if [[ "$domain" =~ ^([a-zA-Z0-9]([a-zA-Z0-9\-]{0,61}[a-zA-Z0-9])?\.)+[a-zA-Z]{2,}$ ]]; then
        return 0
    fi
    return 1
}

validate_url() {
    local url="$1"
    if [[ "$url" =~ ^https?://[a-zA-Z0-9]([a-zA-Z0-9\.\-])*[a-zA-Z0-9](:[0-9]+)?(/.*)?$ ]]; then
        return 0
    fi
    return 1
}

validate_target() {
    local target="$1"
    if validate_ip "$target" || validate_domain "$target"; then
        return 0
    fi
    return 1
}

