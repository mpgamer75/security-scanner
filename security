    [ "$AGGRESSIVE_MODE" = true ] && mode="aggressive"
    echo "[$(date -Iseconds)] Mode: $mode | User: $(whoami)" >> "$LOG_FILE"
}

log_info() {
    [ -n "$LOG_FILE" ] && echo "[$(date -Iseconds)] [INFO] $1" >> "$LOG_FILE"
}

log_warn() {
